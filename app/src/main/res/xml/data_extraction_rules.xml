<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Specifies which data files should be included in backup -->
    <extractable
        android:targetPackage="com.example.terraconnection"
        android:path="path/to/important/data/file" />

    <!-- Exclude specific files or directories -->
    <exclude
        android:targetPackage="com.example.terraconnection"
        android:path="path/to/unwanted/data" />
</data-extraction-rules>